generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int       @id @default(autoincrement())
  nameAr    String
  nameEn    String
  parentId  Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  products  Product[]

  @@map("categories")
}

model Product {
  id         Int       @id @default(autoincrement())
  barcode    String    @unique
  nameAr     String
  nameEn     String
  price      Float
  cost       Float
  stock      Int       @default(0)
  minStock   Int       @default(10)
  unit       String    @default("piece")
  image      String?
  categoryId Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  category   Category?  @relation(fields: [categoryId], references: [id])
  invoiceItems InvoiceItem[]
  purchaseItems PurchaseItem[]

  @@map("products")
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  address   String?
  balance   Float     @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  invoices    Invoice[]
  transactions Transaction[]

  @@map("customers")
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  address   String?
  balance   Float     @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  purchases  Purchase[]
  transactions Transaction[]

  @@map("suppliers")
}

model Invoice {
  id            Int       @id @default(autoincrement())
  number        String    @unique
  type          String    @default("sale")
  status        String    @default("completed")
  customerId    Int?
  subtotal      Float
  vatRate       Float     @default(5)
  vatAmount     Float
  discount      Float     @default(0)
  total         Float
  paid          Float
  remaining     Float
  paymentMethod String    @default("cash")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer      Customer?   @relation(fields: [customerId], references: [id])
  items        InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  productId   Int
  productName String
  barcode     String
  quantity    Int
  price      Float
  discount    Float    @default(0)
  total      Float

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model Purchase {
  id            Int       @id @default(autoincrement())
  number        String    @unique
  status        String    @default("completed")
  supplierId    Int
  subtotal      Float
  vatRate       Float     @default(5)
  vatAmount     Float
  discount      Float     @default(0)
  total         Float
  paid          Float
  remaining     Float
  paymentMethod String    @default("cash")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  supplier      Supplier     @relation(fields: [supplierId], references: [id])
  items         PurchaseItem[]

  @@map("purchases")
}

model PurchaseItem {
  id          Int      @id @default(autoincrement())
  purchaseId  Int
  productId   Int
  productName String
  barcode     String
  quantity    Int
  price      Float
  total      Float

  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

model Transaction {
  id          Int       @id @default(autoincrement())
  type        String
  amount      Float
  description String
  customerId  Int?
  supplierId  Int?
  createdAt   DateTime  @default(now())

  customer    Customer?  @relation(fields: [customerId], references: [id])
  supplier    Supplier?  @relation(fields: [supplierId], references: [id])

  @@map("transactions")
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("settings")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  role      String    @default("cashier")
  name      String
  createdAt DateTime  @default(now())

  @@map("users")
}
